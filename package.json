{
  "name": "react-use-copy",
  "version": "1.1.0",
  "description": "A lightweight React hook for copying text to the clipboard with TypeScript support.",
  "license": "MIT",
  "author": "Vishal Tanna",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "react",
    "react-hook",
    "hook",
    "clipboard",
    "copy",
    "copy-to-clipboard",
    "clipboard-api",
    "use-copy",
    "useCopy",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vish05/react-use-copy.git"
  },
  "bugs": {
    "url": "https://github.com/Vish05/react-use-copy/issues"
  },
  "homepage": "https://github.com/Vish05/react-use-copy#readme"
}
